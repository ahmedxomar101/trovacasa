# TrovaCasa Pipeline — Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys.

# Required
# --------
APIFY_API_TOKEN=           # Get from https://console.apify.com/account/integrations
OPENAI_API_KEY=            # Get from https://platform.openai.com/api-keys
SUPABASE_DB_URL=           # Session pooler Postgres connection string from Supabase dashboard
                           # Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Optional — Telegram Notifications
# -----------------------------------
# Set these to receive Telegram alerts for new high-scoring listings.
TELEGRAM_BOT_TOKEN=        # Create a bot via @BotFather on Telegram
TELEGRAM_CHAT_ID=          # Your chat ID (use @userinfobot to find it)
